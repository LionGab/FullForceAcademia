      "id": "update-campaign-status",
      "name": "Update Campaign Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        2000,
        300
      ]
    },
    {
      "parameters": {
        "language": "javascript",
        "jsCode": "const items = $input.all();\nconst summary = {\n  total_processed: items.length,\n  messages_sent: items.filter(item => item.json.campaign_status === 'SENT').length,\n  timestamp: new Date().toISOString(),\n  campaign_name: 'Ex-Alumni Reactivation'\n};\n\nconsole.log('Campaign Summary:', summary);\nreturn [{ json: summary }];"
      },
      "id": "log-results",
      "name": "Log Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2220,
        300
      ]
    }
