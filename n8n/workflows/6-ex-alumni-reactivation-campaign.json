      ]
    },
    {
      "parameters": {
        "operation": "readOrSearch",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "16ftXuNF2ssAG74dPcsZaCJD4TxfYEjd-bnrRjk7l68I"
        },
